---
import Layout from '../layouts/Layout.astro';
import ThanksWrapper from '../components/ThanksWrapper.astro';
---

<Layout title="Message envoyé ! | vbesse.com">
  <ThanksWrapper>
    <div class="icon">✅</div>
    <h1>Merci beaucoup !</h1>
    <p>Votre message a bien été envoyé. Je fais de mon mieux pour vous répondre sous 48h.</p>
    
    <a href="/" class="button primary">Retour à l'accueil</a>
  </ThanksWrapper>
</Layout>