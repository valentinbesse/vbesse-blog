---
import Layout from '../layouts/Layout.astro';
import ContactWrapper from '../components/ContactWrapper.astro';
import ContactScript from '../components/ContactScript.astro';
---

<Layout title="Me contacter | vbesse.com">
  <ContactWrapper>
    <h1>Me contacter</h1>
    <p>Une question sur un article, une proposition de projet ou juste envie de dire bonjour ? N'hésitez pas !</p>

    <form id="contact-form" action="https://formspree.io/f/mjgeeayp" method="POST" class="contact-form">
      <div class="form-group">
        <label for="name">Nom</label>
        <input type="text" id="name" name="name" required placeholder="Votre nom" />
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="votre@email.com" />
      </div>

      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" required placeholder="Comment puis-je vous aider ?"></textarea>
      </div>

      <button type="submit" id="submit-btn" class="button primary">Envoyer le message</button>
      <p id="form-status" class="status-message"></p>
    </form>
  </ContactWrapper>
  <ContactScript 
    sendingText="Envoi en cours..."
    defaultButtonText="Envoyer le message"
    successRedirectUrl="/thanks"
    errorDefaultText="Oups ! Une erreur est survenue."
    errorNetworkText="Erreur de connexion. Vérifiez votre réseau."
  />
</Layout>
