---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import TagsWrapper from '../../../components/TagsWrapper.astro';

const allPosts = await getCollection('blog', ({ id }) => id.startsWith('en/'));
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())].filter(Boolean);
---

<Layout title="All Topics">
  <TagsWrapper>
    <h1>Explored Topics</h1>
    
    <div class="tags-cloud">
      {tags.map((tag) => (
        <a href={`/en/tags/${tag}`} class="tag-pill">#{tag}</a>
      ))}
    </div>
  </TagsWrapper>
</Layout>