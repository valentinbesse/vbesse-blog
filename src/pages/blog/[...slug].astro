---
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ id }) => id.startsWith('fr/'));

  return posts.map((post) => {
    // On retire 'fr/' du début. 
    // Si l'article est dans fr/tech/post.md, cleanSlug devient 'tech/post'
    const cleanSlug = post.slug.replace(/^fr\//, '');
    
    return {
      // Pour un [...slug], Astro accepte que cleanSlug contienne des '/'
      params: { slug: cleanSlug }, 
      props: post,
    };
  });
}

const post = Astro.props;
const { Content, remarkPluginFrontmatter, headings } = await post.render();

// Lien vers la version EN
const translationUrl = post.data.translation 
  ? `/en/blog/${post.data.translation}/` 
  : null;
---

<BlogPost 
  headings={headings} 
  {...post.data} 
  minutesRead={remarkPluginFrontmatter?.minutesRead}
  translationUrl={translationUrl}
>
  <Content />
</BlogPost>