---
// src/components/LanguagePicker.astro
const currentLocale = Astro.currentLocale || "fr";
---

<div class="lang-picker">
    <a
        href="/"
        class={currentLocale === "fr" ? "active" : ""}
        data-lang="fr"
        aria-label="Passer en français">FR</a
    >
    <span class="divider">|</span>
    <a
        href="/en/"
        class={currentLocale === "en" ? "active" : ""}
        data-lang="en"
        aria-label="Switch to English">EN</a
    >
</div>

<style>
    /* ... (Ton CSS reste le même) ... */
    .lang-picker {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
        font-weight: 600;
        background: var(--bg-secondary);
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        border: 1px solid var(--border-color);
    }
    .lang-picker a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }
    .lang-picker a.active {
        color: var(--accent-color);
        pointer-events: none;
    }
    .divider {
        color: var(--border-color);
        font-weight: normal;
    }
</style>
