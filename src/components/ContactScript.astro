---
// src/components/ContactScript.astro
export interface Props {
  sendingText: string;
  defaultButtonText: string;
  successRedirectUrl: string;
  errorDefaultText: string;
  errorNetworkText: string;
}

const {
  sendingText,
  defaultButtonText,
  successRedirectUrl,
  errorDefaultText,
  errorNetworkText
} = Astro.props;
---

<script define:vars={{ sendingText, defaultButtonText, successRedirectUrl, errorDefaultText, errorNetworkText }}>
  // On crée une fonction d'initialisation
  function setupContactForm() {
    const form = document.getElementById("contact-form");
    const status = document.getElementById("form-status");
    const btn = document.getElementById("submit-btn");

    if (form && btn) {
      // On retire l'éventuel ancien écouteur (bonne pratique avec les transitions)
      form.removeEventListener("submit", handleFormSubmit);
      form.addEventListener("submit", handleFormSubmit);
    }

    async function handleFormSubmit(e) {
      e.preventDefault();
      
      btn.disabled = true;
      btn.textContent = sendingText;
      if (status) status.textContent = "";

      const data = new FormData(form);
      
      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          window.location.href = successRedirectUrl;
        } else {
          const result = await response.json();
          if (result && result.errors) {
            status.textContent = result.errors.map(error => error.message).join(", ");
          } else {
            status.textContent = errorDefaultText;
          }
          btn.disabled = false;
          btn.textContent = defaultButtonText;
        }
      } catch (error) {
        if (status) status.textContent = errorNetworkText;
        btn.disabled = false;
        btn.textContent = defaultButtonText;
      }
    }
  }

  // 1. On lance au premier chargement
  setupContactForm();
  
  // 2. On relance après chaque navigation Astro
  document.addEventListener("astro:page-load", setupContactForm);
</script>