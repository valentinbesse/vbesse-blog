---
// src/components/Prose.astro
---

<div class="prose">
    <slot />
</div>

<style is:global>
    /* is:global permet d'appliquer ces styles aux enfants du <slot />.
      On préfixe tout par .prose pour protéger le reste du site.
    */
    .prose {
        max-width: 800px;
        margin: 0 auto;
        font-size: 1.1rem;
        line-height: 1.8;
    }

    .prose h1 {
        font-size: 2.5rem;
        margin-bottom: 2rem;
    }

    .prose h3 {
        font-size: 1.5rem;
        margin-top: 2rem;
        margin-bottom: 1rem;
        color: var(--text-color);
    }

    .prose p {
        margin-bottom: 1.5rem;
    }

    .prose ul {
        margin: 1.5rem 0;
        padding-left: 1.5rem;
    }

    .prose li {
        margin-bottom: 0.5rem;
    }

    .prose blockquote {
        border-left: 4px solid var(--accent-color);
        margin: 2rem 0;
        padding-left: 1rem;
        font-style: italic;
        color: var(--text-muted);
        background: var(--bg-color);
        padding: 1rem;
        border-radius: 0 8px 8px 0;
    }

    .prose .text-gradient {
        color: var(--accent-color);
    }
</style>